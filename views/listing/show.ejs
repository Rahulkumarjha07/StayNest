<% layout("layouts/boilerplate") %>

<div class="container mt-4">

  <div class="card shadow-sm rounded-4 overflow-hidden">

    <!-- Image -->
    <img
      src="<%= listing.image.url %>"
      alt="Listing Image"
      class="card-img-top"
      style="height:400px; object-fit:cover;"
    />

    <div class="card-body p-4">

      <!-- Title -->
      <h2 class="fw-bold mb-3"><%= listing.title %></h2>

      <!-- Description -->
      <p class="text-muted"><%= listing.description %></p>

      <hr>

      <!-- Details -->
      <div class="row">
        <div class="col-md-4">
          <p><strong>Price:</strong><br> ₹ <%= listing.price %></p>
        </div>
        <div class="col-md-4">
          <p><strong>Location:</strong><br> <%= listing.location %></p>
        </div>
        <div class="col-md-4">
          <p><strong>Country:</strong><br> <%= listing.country %></p>
        </div>
      </div>

      <!-- Owner Buttons -->
      <% if (curruser && listing.owner.equals(curruser._id)) { %>
        <div class="mt-4 d-flex gap-3">
          <a href="/listings/<%= listing._id %>/edit"
             class="btn btn-warning rounded-pill px-4">
            ✏️ Edit
          </a>

          <form method="POST"
                action="/listings/<%= listing._id %>?_method=DELETE">
            <button class="btn btn-danger rounded-pill px-4">
              🗑 Delete
            </button>
          </form>
        </div>
      <% } %>

      <!-- Back Button -->
      <div class="mt-4">
        <a href="/listings"
           class="btn btn-outline-dark rounded-pill px-4">
          ⬅ Back to Listings
        </a>
      </div>

    </div>
  </div>

  <!-- ================= REVIEW SECTION ================= -->

  <div class="row justify-content-center mt-5">
    <div class="col-md-8">

      <h4 class="mb-4 fw-bold">Leave a Review</h4>

      <% if (curruser) { %>
        <div class="card shadow-sm rounded-4 p-4 border-0">

          <form action="/listings/<%= listing._id %>/reviews"
                method="POST"
                class="needs-validation"
                novalidate>

            <!-- Rating -->
            <div class="mb-3">
              <label class="form-label fw-semibold">Rating</label>
              <input
                type="number"
                name="review[rating]"
                class="form-control"
                min="1"
                max="5"
                required>
              <div class="invalid-feedback">
                Please enter a rating between 1 and 5.
              </div>
            </div>

            <!-- Comment -->
            <div class="mb-3">
              <label class="form-label fw-semibold">Comment</label>
              <textarea
                name="review[comment]"
                class="form-control"
                rows="4"
                required></textarea>
              <div class="invalid-feedback">
                Comment cannot be empty.
              </div>
            </div>

            <button class="btn btn-dark rounded-pill px-4">
              Submit Review
            </button>

          </form>

        </div>
      <% } else { %>
        <p>Please <a href="/login">login</a> to leave a review.</p>
      <% } %>

      <!-- Review List -->
      <h4 class="mt-5 mb-3 fw-bold">Reviews</h4>

      <div class="row">
        <% for (let review of listing.reviews) { %>

          <div class="col-md-6 mb-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 h-100">

              <div class="d-flex justify-content-between align-items-center mb-2">

                <!-- Stars -->
                <div>
                  <% for (let i = 1; i <= 5; i++) { %>
                    <% if (i <= review.rating) { %>
                      <span class="text-warning fs-5">★</span>
                    <% } else { %>
                      <span class="text-muted fs-5">★</span>
                    <% } %>
                  <% } %>
                </div>

                <!-- Date -->
                <small class="text-muted">
                  <%= review.createdAt.toDateString() %>
                </small>

              </div>

              <p class="mb-0"><%= review.comment %></p>

            </div>
          </div>

        <% } %>
      </div>

    </div>
  </div>

</div>