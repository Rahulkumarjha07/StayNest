<% layout("layouts/boilerplate") %>

<div class="details-container">

  <h2 class="details-title"><%= listing.title %></h2>

  <div class="details-card">

    <img
      src="<%= listing.image.url %>"
      alt="Listing Image"
      class="details-image"
    />

    <div class="details-info">
      <p class="description"><%= listing.description %></p>

      <p><strong>Price:</strong> ₹ <%= listing.price %></p>
      <p><strong>Location:</strong> <%= listing.location %></p>
      <p><strong>Country:</strong> <%= listing.country %></p>
    </div>

    <!-- Owner Controls -->
    
      <div class="details-actions">
        <a href="/listings/<%= listing._id %>/edit" class="btn edit-btn">
          ✏️ Edit Listing
        </a>

        <form method="post"
              action="/listings/<%= listing._id %>?_method=DELETE"
              class="delete-form">
          <button class="btn delete-btn">
            🗑️ Delete Listing
          </button>
        </form>
        <a href="/listings" class="btn back-btn">
          ⬅ Back to Listings
        </a>
      </div>
    


  </div>

  <hr>

  <!-- ================= REVIEW SECTION ================= -->

  <% if (curruser) { %>

    <div class="mb-3 mt-3">
      <h4>Leave a review</h4>

      <form action="/listings/<%= listing._id %>/reviews"
            method="POST"
            class="needs-validation"
            novalidate>

        <!-- Rating -->
        <div class="mb-3">
          <label class="form-label">Rating</label>
          <input type="number"
                 name="review[rating]"
                 class="form-control"
                 min="1"
                 max="5"
                 required>
        </div>

        <!-- Comment -->
        <div class="mb-3">
          <label class="form-label">Comment</label>
          <textarea name="review[comment]"
                    class="form-control"
                    required></textarea>
        </div>

        <button class="btn btn-dark">Submit Review</button>
      </form>

    </div>

  <% } else { %>
    <p>Please <a href="/login">login</a> to leave a review.</p>
  <% } %>

  <!-- ================= REVIEW LIST ================= -->

  <h4 class="mt-4 mb-3">Reviews</h4>

  <div class="row">
    <% for (let review of listing.reviews) { %>

      <div class="col-md-6 mb-3">
        <div class="card border-0 shadow-sm rounded-4 p-3 h-100">

          <div class="d-flex justify-content-between align-items-center mb-2">

            <!-- Stars -->
            <div>
              <% for (let i = 1; i <= 5; i++) { %>
                <% if (i <= review.rating) { %>
                  <span class="text-warning fs-5">★</span>
                <% } else { %>
                  <span class="text-muted fs-5">★</span>
                <% } %>
              <% } %>
            </div>

            <small class="text-muted">
              <%= review.createdAt.toDateString() %>
            </small>
          </div>

          <p class="mb-0"><%= review.comment %></p>

          <!-- Delete Review (Author Only) -->
          <% if (curruser && review.author && review.author.equals(curruser._id)) { %>
            <form method="POST"
                  action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
              <button class="btn btn-sm btn-danger mt-2">
                Delete
              </button>
            </form>
          <% } %>

        </div>
      </div>

    <% } %>
  </div>

</div>