<% layout("layouts/boilerplate") %>

<style>
  body {
    background: linear-gradient(135deg, #f3f4f6, #e5e7eb);
  }

  .auth-wrapper {
    height: 100vh;
  }

  .auth-container {
    max-width: 1100px;
  }

  .left-image {
    height: 480px;
    border-radius: 25px;
    overflow: hidden;
    box-shadow: 0 25px 50px rgba(0,0,0,0.1);
  }

  .left-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .auth-card {
    background: white;
    border-radius: 25px;
    padding: 40px;
    box-shadow: 0 25px 50px rgba(0,0,0,0.08);
  }

  .form-control {
    border-radius: 12px;
    padding: 12px;
    border: 1px solid #ddd;
  }

  .form-control:focus {
    box-shadow: none;
    border-color: #e76f51;
  }

  .continue-btn {
    background: linear-gradient(135deg, #e76f51, #f4a261);
    border: none;
    border-radius: 50px;
    padding: 12px;
    font-weight: 600;
    font-size: 18px;
    transition: 0.3s;
  }

  .continue-btn:hover {
    opacity: 0.9;
  }

  @media(max-width:768px){
    .left-image{
      display:none;
    }
    .auth-card{
      margin-top:20px;
    }
  }
</style>

<div class="container-fluid auth-wrapper d-flex justify-content-center align-items-center">
  <div class="row w-100 auth-container">

    <!-- LEFT IMAGE -->
    <div class="col-md-6 d-flex justify-content-center align-items-center">
      <div class="left-image w-100">
        <img src="https://images.unsplash.com/photo-1560185127-6ed189bf02f4" alt="Luxury Bedroom">
      </div>
    </div>

    <!-- RIGHT FORM -->
    <div class="col-md-6 d-flex justify-content-center align-items-center">
      <div class="auth-card w-100">

        <h2 class="mb-4 fw-bold text-center">Sign up for StayHub</h2>

        <!-- Flash Messages -->
        <% if(success){ %>
          <div class="alert alert-success alert-dismissible fade show" role="alert">
            <%= success %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% } %>

        <% if(error){ %>
          <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <%= error %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% } %>

        <form action="/signup" method="POST">

          <div class="mb-3">
            <input type="email" name="email" class="form-control" placeholder="Email" required>
          </div>

          <div class="mb-3">
            <input type="text" name="username" class="form-control" placeholder="Username" required>
          </div>

          <div class="mb-4">
            <input type="password" name="password" class="form-control" placeholder="Password" required>
          </div>

          <button class="btn continue-btn w-100 text-white">
            Continue
          </button>

        </form>

        <p class="text-center mt-4 text-muted" style="font-size:14px;">
          Already have an account?
          <a href="/login" class="fw-semibold text-decoration-none">Log in</a>
        </p>

      </div>
    </div>

  </div>
</div>