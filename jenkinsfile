pipeline {
    agent any

    parameters {
        booleanParam(
            name: 'DESTROY',
            defaultValue: false,
            description: 'Destroy complete infrastructure'
        )
    }

    environment {
        PATH = "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
        IMAGE = "vyshnavi1411/staynest:v3"
        AWS_REGION = "ap-south-1"
        CLUSTER_NAME = "staynest-cluster"
    }

    stages {

        stage('Terraform Init') {
            steps {
                dir('terraform') {
                    sh 'terraform init'
                }
            }
        }

        stage('Terraform Apply') {

            when {
                expression { params.DESTROY == false }
            }

            steps {
                dir('terraform') {
                    sh 'terraform apply -auto-approve'
                }
            }
        }

        stage('Update kubeconfig') {

            when {
                expression { params.DESTROY == false }
            }

            steps {
                sh '''
                aws eks update-kubeconfig \
                --region $AWS_REGION \
                --name $CLUSTER_NAME
                '''
            }
        }

        stage('Install Ingress Controller') {

            when {
                expression { params.DESTROY == false }
            }

            steps {
                sh '''
                kubectl apply -f \
                https://raw.githubusercontent.com/kubernetes/ingress-nginx/main/deploy/static/provider/cloud/deploy.yaml
                '''
            }
        }

        stage('Create Kubernetes Secret') {

            when {
                expression { params.DESTROY == false }
            }

            steps {

                withCredentials([
                    string(credentialsId: 'mongo-url', variable: 'MONGO_URL'),
                    string(credentialsId: 'mapbox-token', variable: 'MAPBOX_TOKEN'),
                    string(credentialsId: 'cloudinary-name', variable: 'CLOUD_NAME'),
                    string(credentialsId: 'cloudinary-key', variable: 'API_KEY'),
                    string(credentialsId: 'cloudinary-secret', variable: 'API_SECRET'),
                    string(credentialsId: 'session-secret', variable: 'SECRET')
                ]) {

                    sh '''
                    kubectl delete secret staynest-secret --ignore-not-found=true

                    kubectl create secret generic staynest-secret \
                    --from-literal=MONGO_URL=$MONGO_URL \
                    --from-literal=MAPBOX_TOKEN=$MAPBOX_TOKEN \
                    --from-literal=CLOUD_NAME=$CLOUD_NAME \
                    --from-literal=API_KEY=$API_KEY \
                    --from-literal=API_SECRET=$API_SECRET \
                    --from-literal=SECRET=$SECRET
                    '''
                }
            }
        }

        stage('Build & Push Docker Image') {

            when {
                expression { params.DESTROY == false }
            }

            steps {

                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-creds',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {

                    sh '''
                    echo $DOCKER_PASS | docker login \
                    -u $DOCKER_USER --password-stdin

                    docker buildx create --use || true

                    docker buildx build \
                    --platform linux/amd64 \
                    -t $IMAGE \
                    --push .
                    '''
                }
            }
        }

        stage('Deploy to Kubernetes') {

            when {
                expression { params.DESTROY == false }
            }

            steps {
                sh '''
                kubectl apply -f kubernetes/

                kubectl rollout restart deployment staynest
                '''
            }
        }

        stage('Verify Deployment') {

            when {
                expression { params.DESTROY == false }
            }

            steps {
                sh 'kubectl get pods'
                sh 'kubectl get svc'
                sh 'kubectl get ingress'
            }
        }

        stage('Destroy Infrastructure') {

            when {
                expression { params.DESTROY == true }
            }

            steps {

                input message: 'Are you sure you want to destroy all AWS and Kubernetes infrastructure?', ok: 'Destroy'

                sh '''
                kubectl delete -f kubernetes/ --ignore-not-found=true
                '''

                sh '''
                kubectl delete -f \
                https://raw.githubusercontent.com/kubernetes/ingress-nginx/main/deploy/static/provider/cloud/deploy.yaml \
                --ignore-not-found=true
                '''

                dir('terraform') {
                    sh 'terraform destroy -auto-approve'
                }
            }
        }
    }
}